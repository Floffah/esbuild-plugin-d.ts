{
    "name": "esbuild-plugin-d.ts",
    "version": "1.3.1",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "require": {
            "types": "./dist/index.d.cts",
            "default": "./dist/index.cjs"
        },
        "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/floffah/esbuild-plugin-d.ts.git"
    },
    "author": "Floffah <therealfloffah@gmail.com>",
    "license": "MIT",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "build": "tsdown",
        "test": "bun test",
        "deps": "bunx ncu -x chalk -x eslint",
        "lint": "bunx eslint . --ext .ts && attw --pack . && publint --package . --pack npm",
        "release": "changeset publish"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "peerDependencies": {
        "typescript": ">=5.5.0 <6"
    },
    "dependencies": {
        "chalk": "4.1.2",
        "dts-bundle-generator": "^9.5.1",
        "type-fest": "^4.26.1"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@changesets/changelog-github": "^0.6.0",
        "@changesets/cli": "^2.30.0",
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@trivago/prettier-plugin-sort-imports": "^4.3.0",
        "@tsconfig/node20": "^20.1.6",
        "@types/bun": "^1.3.10",
        "@types/tmp": "^0.2.6",
        "esbuild": "^0.21.5",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "jiti": "^2.6.1",
        "npm-check-updates": "^16.14.20",
        "prettier": "^3.3.2",
        "publint": "^0.3.18",
        "tsdown": "^0.21.4",
        "typescript": "^5.5.2",
        "typescript-eslint": "^8.57.1"
    },
    "packageManager": "bun@1.3.10"
}
